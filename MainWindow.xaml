<Window x:Class="Site_Workforce_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
        xmlns:viewModels="clr-namespace:Site_Workforce_Manager.ViewModels"
        xmlns:views="clr-namespace:Site_Workforce_Manager.Views"
        mc:Ignorable="d"
        Title="Site Workforce Manager"
        Height="720"
        Width="1200"
        MinHeight="650"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TradesViewModel}">
            <views:TradesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WorkersViewModel}">
            <views:WorkersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ConstructionSitesViewModel}">
            <views:ConstructionSitesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WorkLogsViewModel}">
            <views:WorkLogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PayrollViewModel}">
            <views:PayrollView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WorkerBalancesViewModel}">
            <views:WorkerBalancesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MaintenanceViewModel}">
            <views:MaintenanceView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Margin="20"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="24">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Margin="0,0,0,4"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Site Workforce" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,20,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Margin="0,0,0,12"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#94A3B8"
                                   Text="NAVIGATION" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowDashboardCommand}"
                                Content="Dashboard"
                                helpers:NavigationState.IsActive="{Binding IsDashboardActive}"
                                Tag="Dashboard"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowTradesCommand}"
                                Content="Trades"
                                helpers:NavigationState.IsActive="{Binding IsTradesActive}"
                                Tag="Trades"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowWorkersCommand}"
                                Content="Workers"
                                helpers:NavigationState.IsActive="{Binding IsWorkersActive}"
                                Tag="Workers"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowConstructionSitesCommand}"
                                Content="Construction Sites"
                                helpers:NavigationState.IsActive="{Binding IsConstructionSitesActive}"
                                Tag="ConstructionSites"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowWorkLogsCommand}"
                                Content="Work Logs"
                                helpers:NavigationState.IsActive="{Binding IsWorkLogsActive}"
                                Tag="WorkLogs"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowReportsCommand}"
                                Content="Reports"
                                helpers:NavigationState.IsActive="{Binding IsReportsActive}"
                                Tag="Reports"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowPayrollCommand}"
                                Content="Payroll"
                                helpers:NavigationState.IsActive="{Binding IsPayrollActive}"
                                Tag="Payroll"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowWorkerBalancesCommand}"
                                Content="Worker Balances"
                                helpers:NavigationState.IsActive="{Binding IsWorkerBalancesActive}"
                                Tag="WorkerBalances"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Command="{Binding ShowMaintenanceCommand}"
                                Content="Maintenance"
                                helpers:NavigationState.IsActive="{Binding IsMaintenanceActive}"
                                Tag="Maintenance"
                                Style="{StaticResource SidebarButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1"
                        Margin="0,20,20,20"
                        Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
