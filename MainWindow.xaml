<Window x:Class="Site_Workforce_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
        xmlns:viewModels="clr-namespace:Site_Workforce_Manager.ViewModels"
        xmlns:views="clr-namespace:Site_Workforce_Manager.Views"
        mc:Ignorable="d"
        Title="Site Workforce Manager"
        Height="720"
        Width="1200"
        MinHeight="650"
        MinWidth="1000"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TradesViewModel}">
            <views:TradesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WorkersViewModel}">
            <views:WorkersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ConstructionSitesViewModel}">
            <views:ConstructionSitesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WeeklyWorkEntryViewModel}">
            <views:WeeklyWorkEntryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PayrollViewModel}">
            <views:PayrollView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WeeklyReportViewModel}">
            <views:WeeklyReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WorkerBalancesViewModel}">
            <views:WorkerBalancesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MaintenanceViewModel}">
            <views:MaintenanceView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Margin="16"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid Margin="16,20,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- App logo and name -->
                <StackPanel Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="9"
                                Background="{StaticResource PrimaryBrush}"
                                Margin="0,0,10,0">
                            <TextBlock Text="S" Foreground="White" FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Site Workforce" LineHeight="18" />
                            <TextBlock FontSize="10.5"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Manager" LineHeight="14" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Row="1" Height="1"
                        Background="{StaticResource BorderBrush}"
                        Margin="0,16,0,4" />

                <ScrollViewer Grid.Row="2"
                              Margin="0,4,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Margin="4,6,0,8"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="MENU" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowDashboardCommand}"
                                Content="Dashboard"
                                helpers:NavigationState.IsActive="{Binding IsDashboardActive}"
                                Tag="Dashboard"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowTradesCommand}"
                                Content="Categories"
                                helpers:NavigationState.IsActive="{Binding IsTradesActive}"
                                Tag="Trades"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowConstructionSitesCommand}"
                                Content="Construction Sites"
                                helpers:NavigationState.IsActive="{Binding IsConstructionSitesActive}"
                                Tag="ConstructionSites"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowWorkersCommand}"
                                Content="Workers"
                                helpers:NavigationState.IsActive="{Binding IsWorkersActive}"
                                Tag="Workers"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowWeeklyWorkEntryCommand}"
                                Content="Weekly Entry"
                                helpers:NavigationState.IsActive="{Binding IsWeeklyWorkEntryActive}"
                                Tag="WeeklyWorkEntry"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowPayrollCommand}"
                                Content="Payroll"
                                helpers:NavigationState.IsActive="{Binding IsPayrollActive}"
                                Tag="Payroll"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowReportsCommand}"
                                Content="Reports"
                                helpers:NavigationState.IsActive="{Binding IsReportsActive}"
                                Tag="Reports"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowWeeklyReportCommand}"
                                Content="Weekly Report"
                                helpers:NavigationState.IsActive="{Binding IsWeeklyReportActive}"
                                Tag="WeeklyReport"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Margin="0,0,0,8"
                                Command="{Binding ShowWorkerBalancesCommand}"
                                Content="Worker Balances"
                                helpers:NavigationState.IsActive="{Binding IsWorkerBalancesActive}"
                                Tag="WorkerBalances"
                                Style="{StaticResource SidebarButtonStyle}" />

                        <Button Command="{Binding ShowMaintenanceCommand}"
                                Content="Maintenance"
                                helpers:NavigationState.IsActive="{Binding IsMaintenanceActive}"
                                Tag="Maintenance"
                                Style="{StaticResource SidebarButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1"
                        Margin="0,16,16,16"
                        Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
