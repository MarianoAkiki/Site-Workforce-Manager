<Window x:Class="Site_Workforce_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Site_Workforce_Manager.ViewModels"
        xmlns:views="clr-namespace:Site_Workforce_Manager.Views"
        mc:Ignorable="d"
        Title="Site Workforce Manager"
        Height="720"
        Width="1200"
        MinHeight="650"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TradesViewModel}">
            <views:TradesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WorkersViewModel}">
            <views:WorkersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ConstructionSitesViewModel}">
            <views:ConstructionSitesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WorkLogsViewModel}">
            <views:WorkLogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PayrollViewModel}">
            <views:PayrollView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:WorkerBalancesViewModel}">
            <views:WorkerBalancesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MaintenanceViewModel}">
            <views:MaintenanceView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Margin="20"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="24">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="48"
                            Height="48"
                            Background="#1D4ED8"
                            CornerRadius="12"
                            HorizontalAlignment="Left">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="SW" />
                    </Border>

                    <TextBlock Margin="0,18,0,4"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Site Workforce" />

                    <TextBlock FontSize="13"
                               Foreground="#CBD5E1"
                               Text="Business dashboard for workers and construction sites" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,36,0,0">
                    <TextBlock Margin="0,0,0,12"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#94A3B8"
                               Text="NAVIGATION" />

                    <Button Margin="0,0,0,12"
                            Command="{Binding ShowDashboardCommand}"
                            Content="Dashboard"
                            Tag="{Binding IsDashboardActive}"
                            Style="{StaticResource SidebarButtonStyle}" />

                    <Button Margin="0,0,0,12"
                            Command="{Binding ShowTradesCommand}"
                            Content="Trades"
                            Tag="{Binding IsTradesActive}"
                            Style="{StaticResource SidebarButtonStyle}" />

                    <Button Margin="0,0,0,12"
                            Command="{Binding ShowWorkersCommand}"
                            Content="Workers"
                            Tag="{Binding IsWorkersActive}"
                            Style="{StaticResource SidebarButtonStyle}" />

                    <Button Margin="0,0,0,12"
                            Command="{Binding ShowConstructionSitesCommand}"
                            Content="Construction Sites"
                            Tag="{Binding IsConstructionSitesActive}"
                            Style="{StaticResource SidebarButtonStyle}" />

                    <Button Margin="0,12,0,0"
                            Command="{Binding ShowWorkLogsCommand}"
                            Content="Work Logs"
                            Tag="{Binding IsWorkLogsActive}"
                            Style="{StaticResource SidebarButtonStyle}" />

                    <Button Margin="0,12,0,0"
                            Command="{Binding ShowReportsCommand}"
                            Content="Reports"
                            Tag="{Binding IsReportsActive}"
                            Style="{StaticResource SidebarButtonStyle}" />

                    <Button Margin="0,12,0,0"
                            Command="{Binding ShowPayrollCommand}"
                            Content="Payroll"
                            Tag="{Binding IsPayrollActive}"
                            Style="{StaticResource SidebarButtonStyle}" />

                    <Button Margin="0,12,0,0"
                            Command="{Binding ShowWorkerBalancesCommand}"
                            Content="Worker Balances"
                            Tag="{Binding IsWorkerBalancesActive}"
                            Style="{StaticResource SidebarButtonStyle}" />

                    <Button Margin="0,12,0,0"
                            Command="{Binding ShowMaintenanceCommand}"
                            Content="Maintenance"
                            Tag="{Binding IsMaintenanceActive}"
                            Style="{StaticResource SidebarButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1"
                        Margin="0,20,20,20"
                        Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
