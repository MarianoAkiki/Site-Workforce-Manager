<UserControl x:Class="Site_Workforce_Manager.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <Style x:Key="MultiSelectRowCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                Padding="10,9"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Box"
                                        Width="16" Height="16"
                                        VerticalAlignment="Center"
                                        Background="White"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1.3"
                                        CornerRadius="4">
                                    <Path x:Name="CheckMark"
                                          Margin="1"
                                          Data="M2,5.3 L4.3,7.6 L9.7,1.8"
                                          Stroke="White"
                                          StrokeThickness="1.6"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                   Margin="9,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Content="{TemplateBinding Content}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DropdownClearButtonStyle" TargetType="Button" BasedOn="{StaticResource FilterClearButtonStyle}">
            <Setter Property="Width"      Value="20" />
            <Setter Property="Height"     Value="20" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="ToolTip"    Value="Clear" />
            <Setter Property="IsTabStop"  Value="False" />
        </Style>

        <Style x:Key="ExcelButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Foreground"  Value="White" />
            <Setter Property="Background"  Value="#217346" />
            <Setter Property="BorderBrush" Value="#217346" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1B5E38" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1B5E38" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#154B2D" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#154B2D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern underline TabControl -->
        <Style x:Key="ReportTabControlStyle" TargetType="TabControl">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <TabPanel x:Name="HeaderPanel"
                                          Background="Transparent"
                                          IsItemsHost="True" />
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Margin="0,16,0,0"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReportTabItemStyle" TargetType="TabItem">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Padding="16,10"
                                Margin="0,0,2,0"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Background="Transparent">
                            <TextBlock x:Name="Lbl"
                                       Text="{TemplateBinding Header}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Lbl" Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd"  Property="BorderBrush"  Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="Lbl" Property="Foreground"   Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="Lbl" Property="FontWeight"   Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Page header -->
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Reports" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="Review work logs across workers and sites with filters and summary totals." />
            </StackPanel>

            <!-- Filters -->
            <Border Grid.Row="1" Margin="0,24,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Filters" />
                    <TextBlock Margin="0,5,0,0" Foreground="{StaticResource TextMutedBrush}"
                               Text="Choose a date range, workers, categories, and sites to analyze." />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Row 1: Dates -->
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Date From" />
                            <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Date To" />
                            <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}" />
                        </StackPanel>

                        <!-- Row 2: Multi-select dropdowns -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,14,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Workers" />
                            <Grid>
                                <ComboBox x:Name="WorkerFilterComboBox"
                                          ItemsSource="{Binding WorkerOptions}"
                                          helpers:SearchableMultiSelectComboBoxBehavior.IsEnabled="True"
                                          helpers:SearchableMultiSelectComboBoxBehavior.SearchText="{Binding WorkerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Style="{StaticResource MultiSelectRowCheckBoxStyle}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="11,0,44,0" VerticalAlignment="Center" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" IsHitTestVisible="False"
                                           Panel.ZIndex="1" Text="{Binding WorkerSelectionSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding ShowWorkerSelectionPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Margin="0,0,18,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Command="{Binding ClearWorkerFilterCommand}" Content="x" Panel.ZIndex="2"
                                        Style="{StaticResource DropdownClearButtonStyle}"
                                        Visibility="{Binding HasWorkerFilter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,14,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Categories" />
                            <Grid>
                                <ComboBox x:Name="TradeFilterComboBox"
                                          ItemsSource="{Binding TradeOptions}"
                                          helpers:SearchableMultiSelectComboBoxBehavior.IsEnabled="True"
                                          helpers:SearchableMultiSelectComboBoxBehavior.SearchText="{Binding TradeSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Style="{StaticResource MultiSelectRowCheckBoxStyle}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="11,0,44,0" VerticalAlignment="Center" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" IsHitTestVisible="False"
                                           Panel.ZIndex="1" Text="{Binding TradeSelectionSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding ShowTradeSelectionPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Margin="0,0,18,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Command="{Binding ClearTradeFilterCommand}" Content="x" Panel.ZIndex="2"
                                        Style="{StaticResource DropdownClearButtonStyle}"
                                        Visibility="{Binding HasTradeFilter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,14,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Construction Sites" />
                            <Grid>
                                <ComboBox x:Name="ConstructionSiteFilterComboBox"
                                          ItemsSource="{Binding ConstructionSiteOptions}"
                                          helpers:SearchableMultiSelectComboBoxBehavior.IsEnabled="True"
                                          helpers:SearchableMultiSelectComboBoxBehavior.SearchText="{Binding ConstructionSiteSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Style="{StaticResource MultiSelectRowCheckBoxStyle}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="11,0,44,0" VerticalAlignment="Center" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" IsHitTestVisible="False"
                                           Panel.ZIndex="1" Text="{Binding ConstructionSiteSelectionSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding ShowConstructionSiteSelectionPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Margin="0,0,18,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Command="{Binding ClearConstructionSiteFilterCommand}" Content="x" Panel.ZIndex="2"
                                        Style="{StaticResource DropdownClearButtonStyle}"
                                        Visibility="{Binding HasConstructionSiteFilter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,14,0,0"
                                    Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button MinWidth="80" Command="{Binding ClearFiltersCommand}"
                                    Content="Clear" Style="{StaticResource BaseButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Results -->
            <Border Grid.Row="2" Margin="0,20,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>

                    <!-- Header row -->
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Report Results" />
                            <TextBlock Margin="0,5,0,0" Foreground="{StaticResource TextMutedBrush}"
                                       Text="Reflects the current filters and weekly work log entries." />
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Command="{Binding RequestExportToExcelCommand}"
                                Content="Export to Excel"
                                Style="{StaticResource ExcelButtonStyle}" />
                    </DockPanel>

                    <!-- Stat strip -->
                    <Border Margin="0,18,0,0"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Dividers -->
                            <Border Grid.Column="1"  Background="{StaticResource BorderBrush}" />
                            <Border Grid.Column="3"  Background="{StaticResource BorderBrush}" />
                            <Border Grid.Column="5"  Background="{StaticResource BorderBrush}" />
                            <Border Grid.Column="7"  Background="{StaticResource BorderBrush}" />
                            <Border Grid.Column="9"  Background="{StaticResource BorderBrush}" />
                            <Border Grid.Column="11" Background="{StaticResource BorderBrush}" />
                            <!-- Stats -->
                            <StackPanel Grid.Column="0"  Margin="0,14,0,14" HorizontalAlignment="Center">
                                <TextBlock FontSize="11"  FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Text="HOURS" />
                                <TextBlock FontSize="20"  FontWeight="Bold" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Text="{Binding TotalHours, StringFormat={}{0:F2}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2"  Margin="0,14,0,14" HorizontalAlignment="Center">
                                <TextBlock FontSize="11"  FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Text="EARNED" />
                                <TextBlock FontSize="20"  FontWeight="Bold" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Text="{Binding TotalAmount, StringFormat={}{0:C}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4"  Margin="0,14,0,14" HorizontalAlignment="Center">
                                <TextBlock FontSize="11"  FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Text="PAID" />
                                <TextBlock FontSize="20"  FontWeight="Bold" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Text="{Binding TotalPaid, StringFormat={}{0:C}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="6"  Margin="0,14,0,14" HorizontalAlignment="Center">
                                <TextBlock FontSize="11"  FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Text="WORKERS" />
                                <TextBlock FontSize="20"  FontWeight="Bold" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Text="{Binding NumberOfWorkers}" />
                            </StackPanel>
                            <StackPanel Grid.Column="8"  Margin="0,14,0,14" HorizontalAlignment="Center">
                                <TextBlock FontSize="11"  FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Text="CATEGORIES" />
                                <TextBlock FontSize="20"  FontWeight="Bold" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Text="{Binding NumberOfTrades}" />
                            </StackPanel>
                            <StackPanel Grid.Column="10" Margin="0,14,0,14" HorizontalAlignment="Center">
                                <TextBlock FontSize="11"  FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Text="SITES" />
                                <TextBlock FontSize="20"  FontWeight="Bold" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Text="{Binding NumberOfConstructionSites}" />
                            </StackPanel>
                            <StackPanel Grid.Column="12" Margin="0,14,0,14" HorizontalAlignment="Center">
                                <TextBlock FontSize="11"  FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Text="LOGS" />
                                <TextBlock FontSize="20"  FontWeight="Bold" Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Text="{Binding NumberOfLogs}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Export confirmation banner -->
                    <Border Margin="0,12,0,0"
                            Background="#FFF7ED"
                            BorderBrush="#F59E0B"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,12"
                            Visibility="{Binding IsExportConfirmationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Export current filtered report?" />
                                <TextBlock Margin="0,3,0,0" Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="This will export all rows and totals exactly as currently filtered." />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                <Button Command="{Binding ConfirmExportToExcelCommand}"
                                        Content="Yes, Export"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Margin="10,0,0,0" Command="{Binding CancelExportToExcelCommand}"
                                        Content="Cancel" Style="{StaticResource BaseButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Export in-progress banner -->
                    <Border Margin="0,12,0,0"
                            Background="#EFF6FF"
                            BorderBrush="#93C5FD"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,12"
                            Visibility="{Binding IsExportInProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ProgressBar Width="140" Height="8" IsIndeterminate="True" VerticalAlignment="Center" />
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                                       FontWeight="SemiBold" Text="Creating Excel file…" />
                        </StackPanel>
                    </Border>

                    <!-- Modern tab views -->
                    <TabControl Margin="0,18,0,0"
                                SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                                Style="{StaticResource ReportTabControlStyle}">

                        <TabItem Header="Detailed Logs" Style="{StaticResource ReportTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          ItemsSource="{Binding ReportWorkLogsPage.Items}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Worker}"                                   Header="Worker"            Width="*" />
                                        <DataGridTextColumn Binding="{Binding Trade}"                                    Header="Category"          Width="130" />
                                        <DataGridTextColumn Binding="{Binding ConstructionSite}"                         Header="Site"              Width="150" />
                                        <DataGridTextColumn Binding="{Binding WorkDate, StringFormat={}{0:yyyy-MM-dd}}"  Header="Date"              Width="105" />
                                        <DataGridTextColumn Binding="{Binding DurationHours, StringFormat={}{0:F2}}"     Header="Hours"             Width="80" />
                                        <DataGridTextColumn Binding="{Binding DailyRate, StringFormat={}{0:C}}"          Header="Daily Rate"        Width="100" />
                                        <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:C}}"        Header="Total"             Width="100" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button Command="{Binding ReportWorkLogsPage.PreviousPageCommand}" Content="&lt; Prev" MinWidth="76" Style="{StaticResource BaseButtonStyle}" />
                                    <TextBlock Margin="14,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Text="{Binding ReportWorkLogsPage.PageInfoText}" />
                                    <Button Command="{Binding ReportWorkLogsPage.NextPageCommand}" Content="Next &gt;" MinWidth="76" Style="{StaticResource BaseButtonStyle}" />
                                    <TextBlock Margin="20,0,6,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Text="Show:" />
                                    <ComboBox MinWidth="68" ItemsSource="{x:Static helpers:PageSizeOptions.Values}" SelectedItem="{Binding ReportWorkLogsPage.PageSize, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="By Worker" Style="{StaticResource ReportTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          ItemsSource="{Binding WorkerSummariesPage.Items}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Worker}"                               Header="Worker"       Width="*" />
                                        <DataGridTextColumn Binding="{Binding NumberOfLogs}"                         Header="Logs"         Width="80" />
                                        <DataGridTextColumn Binding="{Binding TotalHours, StringFormat={}{0:F2}}"    Header="Total Hours"  Width="120" />
                                        <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:C}}"    Header="Total Amount" Width="130" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Button Command="{Binding WorkerSummariesPage.PreviousPageCommand}" Content="&lt; Prev" MinWidth="76" Style="{StaticResource BaseButtonStyle}" />
                                    <TextBlock Margin="14,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Text="{Binding WorkerSummariesPage.PageInfoText}" />
                                    <Button Command="{Binding WorkerSummariesPage.NextPageCommand}" Content="Next &gt;" MinWidth="76" Style="{StaticResource BaseButtonStyle}" />
                                    <TextBlock Margin="20,0,6,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Text="Show:" />
                                    <ComboBox MinWidth="68" ItemsSource="{x:Static helpers:PageSizeOptions.Values}" SelectedItem="{Binding WorkerSummariesPage.PageSize, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="By Category" Style="{StaticResource ReportTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          ItemsSource="{Binding TradeSummariesPage.Items}">
                                    <DataGrid.Columns>
