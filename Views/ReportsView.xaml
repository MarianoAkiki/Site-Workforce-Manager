<UserControl x:Class="Site_Workforce_Manager.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <Style x:Key="DropdownClearButtonStyle" TargetType="Button" BasedOn="{StaticResource FilterClearButtonStyle}">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="ToolTip" Value="Clear" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>
        <Style x:Key="ExcelButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#217346" />
            <Setter Property="BorderBrush" Value="#217346" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1B5E38" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1B5E38" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#154B2D" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#154B2D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}"
                           Text="Reports" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="Review work logs across workers and sites with read-only filters and summary totals." />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Report Filters" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Choose a date range, one or more workers, trades, and sites to analyze." />

                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Date From" />
                            <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Date To" />
                            <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,18,16,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Workers" />
                            <Grid>
                                <ComboBox x:Name="WorkerFilterComboBox"
                                          ItemsSource="{Binding WorkerOptions}"
                                          helpers:SearchableMultiSelectComboBoxBehavior.IsEnabled="True"
                                          helpers:SearchableMultiSelectComboBoxBehavior.SearchText="{Binding WorkerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="10,0,44,0"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           IsHitTestVisible="False"
                                           Panel.ZIndex="1"
                                           Text="{Binding WorkerSelectionSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding ShowWorkerSelectionPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Margin="0,0,18,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ClearWorkerFilterCommand}"
                                        Content="x"
                                        Panel.ZIndex="2"
                                        Style="{StaticResource DropdownClearButtonStyle}"
                                        Visibility="{Binding HasWorkerFilter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,18,16,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Trades" />
                            <Grid>
                                <ComboBox x:Name="TradeFilterComboBox"
                                          ItemsSource="{Binding TradeOptions}"
                                          helpers:SearchableMultiSelectComboBoxBehavior.IsEnabled="True"
                                          helpers:SearchableMultiSelectComboBoxBehavior.SearchText="{Binding TradeSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="10,0,44,0"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           IsHitTestVisible="False"
                                           Panel.ZIndex="1"
                                           Text="{Binding TradeSelectionSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding ShowTradeSelectionPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Margin="0,0,18,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ClearTradeFilterCommand}"
                                        Content="x"
                                        Panel.ZIndex="2"
                                        Style="{StaticResource DropdownClearButtonStyle}"
                                        Visibility="{Binding HasTradeFilter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,18,16,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Construction Sites" />
                            <Grid>
                                <ComboBox x:Name="ConstructionSiteFilterComboBox"
                                          ItemsSource="{Binding ConstructionSiteOptions}"
                                          helpers:SearchableMultiSelectComboBoxBehavior.IsEnabled="True"
                                          helpers:SearchableMultiSelectComboBoxBehavior.SearchText="{Binding ConstructionSiteSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="10,0,44,0"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           IsHitTestVisible="False"
                                           Panel.ZIndex="1"
                                           Text="{Binding ConstructionSiteSelectionSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding ShowConstructionSiteSelectionPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Margin="0,0,18,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ClearConstructionSiteFilterCommand}"
                                        Content="x"
                                        Panel.ZIndex="2"
                                        Style="{StaticResource DropdownClearButtonStyle}"
                                        Visibility="{Binding HasConstructionSiteFilter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Margin="0,18,0,0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button MinWidth="130"
                                    Command="{Binding ApplyFiltersCommand}"
                                    Content="Apply Filters"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button MinWidth="96"
                                    Command="{Binding ClearFiltersCommand}"
                                    Margin="12,0,0,0"
                                    Content="Clear"
                                    Style="{StaticResource BaseButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="Report Results" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="The table reflects the current filters and weekly work log entries." />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Border Margin="12,0,0,0"
                                    Style="{StaticResource SummaryCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Total Hours" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding TotalHours, StringFormat={}{0:F2}}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="12,0,0,0"
                                    Style="{StaticResource SummaryCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Total Amount" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding TotalAmount, StringFormat={}{0:C}}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="12,0,0,0"
                                    Style="{StaticResource SummaryCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Workers" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding NumberOfWorkers}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="12,0,0,0"
                                    Style="{StaticResource SummaryCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Trades" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding NumberOfTrades}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="12,0,0,0"
                                    Style="{StaticResource SummaryCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Sites" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding NumberOfConstructionSites}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="12,0,0,0"
                                    Style="{StaticResource SummaryCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Logs" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding NumberOfLogs}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <Border Margin="0,18,0,0"
                            Background="#F8FAFF"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Command="{Binding RequestExportToExcelCommand}"
                                    Content="Export Current View to Excel"
                                    Style="{StaticResource ExcelButtonStyle}" />

                            <Border Grid.Column="1"
                                    Margin="16,0,0,0"
                                    Background="#FFF7ED"
                                    BorderBrush="#F59E0B"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14,12"
                                    Visibility="{Binding IsExportConfirmationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Export current filtered report?" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="This will export the rows and totals exactly as they are currently filtered on this page." />
                                    <StackPanel Margin="0,12,0,0"
                                                Orientation="Horizontal">
                                        <Button Command="{Binding ConfirmExportToExcelCommand}"
                                                Content="Yes, Export"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button Margin="12,0,0,0"
                                                Command="{Binding CancelExportToExcelCommand}"
                                                Content="Cancel"
                                                Style="{StaticResource BaseButtonStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="16,0,0,0"
                                    Background="#EFF6FF"
                                    BorderBrush="#93C5FD"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14,12"
                                    Visibility="{Binding IsExportInProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <ProgressBar Width="140"
                                                 Height="10"
                                                 IsIndeterminate="True"
                                                 VerticalAlignment="Center" />
                                    <TextBlock Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="Creating Excel file..." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <TabControl Margin="0,18,0,0">
                        <TabItem Header="Detailed Logs">
                            <DataGrid AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding ReportWorkLogs}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Worker}" Header="Worker Name" Width="170" />
                                    <DataGridTextColumn Binding="{Binding Trade}" Header="Trade Name" Width="140" />
                                    <DataGridTextColumn Binding="{Binding ConstructionSite}" Header="Construction Site" Width="180" />
                                    <DataGridTextColumn Binding="{Binding WorkDate, StringFormat={}{0:yyyy-MM-dd}}" Header="Work Date" Width="110" />
                                    <DataGridTextColumn Binding="{Binding DurationHours, StringFormat={}{0:F2}}" Header="Duration Hours" Width="110" />
                                    <DataGridTextColumn Binding="{Binding DailyRate, StringFormat={}{0:C}}" Header="Daily Rate" Width="100" />
                                    <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Header="Total Amount" Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Summary by Worker">
                            <DataGrid AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding WorkerSummaries}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Worker}" Header="Worker Name" Width="*" />
                                    <DataGridTextColumn Binding="{Binding NumberOfLogs}" Header="Logs" Width="90" />
                                    <DataGridTextColumn Binding="{Binding TotalHours, StringFormat={}{0:F2}}" Header="Total Hours" Width="120" />
                                    <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Header="Total Amount" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Summary by Trade">
                            <DataGrid AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding TradeSummaries}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Trade}" Header="Trade Name" Width="*" />
                                    <DataGridTextColumn Binding="{Binding NumberOfLogs}" Header="Logs" Width="90" />
                                    <DataGridTextColumn Binding="{Binding TotalHours, StringFormat={}{0:F2}}" Header="Total Hours" Width="120" />
                                    <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Header="Total Amount" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Summary by Construction Site">
                            <DataGrid AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding ConstructionSiteSummaries}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding ConstructionSite}" Header="Construction Site" Width="*" />
                                    <DataGridTextColumn Binding="{Binding NumberOfLogs}" Header="Logs" Width="90" />
                                    <DataGridTextColumn Binding="{Binding TotalHours, StringFormat={}{0:F2}}" Header="Total Hours" Width="120" />
                                    <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Header="Total Amount" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Summary by Date">
                            <DataGrid AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding DateSummaries}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding WorkDate, StringFormat={}{0:yyyy-MM-dd}}" Header="Work Date" Width="*" />
                                    <DataGridTextColumn Binding="{Binding NumberOfLogs}" Header="Logs" Width="90" />
                                    <DataGridTextColumn Binding="{Binding TotalHours, StringFormat={}{0:F2}}" Header="Total Hours" Width="120" />
                                    <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Header="Total Amount" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
