<UserControl x:Class="Site_Workforce_Manager.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}"
                           Text="Reports" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="Review work logs across workers and sites with read-only filters and summary totals." />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Report Filters" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Choose a date range, one or more workers, one or more sites, and the payment status you want to analyze." />

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Date From" />
                            <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Date To" />
                            <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Workers" />
                            <Border Style="{StaticResource FilterPanelBorderStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="130">
                                    <ItemsControl ItemsSource="{Binding WorkerOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Margin="0,0,0,8"
                                                          Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Construction Sites" />
                            <Border Style="{StaticResource FilterPanelBorderStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="130">
                                    <ItemsControl ItemsSource="{Binding ConstructionSiteOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Margin="0,0,0,8"
                                                          Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Payment Status" />
                            <ComboBox ItemsSource="{Binding PaymentStatusOptions}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedPaymentStatusOption, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Column="5"
                                    Margin="0,24,12,0"
                                    VerticalAlignment="Bottom">
                            <Button Command="{Binding ApplyFiltersCommand}"
                                    Content="Apply Filters"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="6"
                                    Margin="0,24,0,0"
                                    VerticalAlignment="Bottom">
                            <Button Command="{Binding ClearFiltersCommand}"
                                    Content="Clear"
                                    Style="{StaticResource BaseButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       Text="Report Results" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Cancelled logs appear only when that status is selected, and they are excluded from totals." />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Border Margin="12,0,0,0"
                                    Style="{StaticResource SummaryCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Total Hours" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding TotalHours, StringFormat={}{0:F2}}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="12,0,0,0"
                                    Style="{StaticResource SummaryCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Total Amount" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding TotalAmount, StringFormat={}{0:C}}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Margin="0,18,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding ReportWorkLogs}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Worker}" Header="Worker" Width="170" />
                            <DataGridTextColumn Binding="{Binding ConstructionSite}" Header="Construction Site" Width="180" />
                            <DataGridTextColumn Binding="{Binding WorkDate, StringFormat={}{0:yyyy-MM-dd}}" Header="Work Date" Width="110" />
                            <DataGridTextColumn Binding="{Binding StartTime}" Header="Start Time" Width="90" />
                            <DataGridTextColumn Binding="{Binding EndTime}" Header="End Time" Width="90" />
                            <DataGridTextColumn Binding="{Binding DurationHours, StringFormat={}{0:F2}}" Header="Duration Hours" Width="110" />
                            <DataGridTextColumn Binding="{Binding HourlyRate, StringFormat={}{0:C}}" Header="Hourly Rate" Width="100" />
                            <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Header="Total Amount" Width="110" />
                            <DataGridTextColumn Binding="{Binding PaymentStatus}" Header="Payment Status" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
