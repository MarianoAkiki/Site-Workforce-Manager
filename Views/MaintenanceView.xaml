<UserControl x:Class="Site_Workforce_Manager.Views.MaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <Style x:Key="UpdateProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Background" Value="#E2E8F0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Maintenance" />
            <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                       Text="Manage database backups and restore points." />

            <!-- Database path -->
            <Border Margin="0,24,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Database File" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Current database location on disk." />
                    <TextBox Margin="0,16,0,0" IsReadOnly="True" Text="{Binding DatabasePath}" />
                </StackPanel>
            </Border>

            <!-- Backup -->
            <Border Margin="0,20,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Automatic Backup" />

                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"
                               Text="Backs up once per app launch to a folder of your choice (OneDrive, Google Drive, etc.). Older backups are deleted automatically when the limit is reached." />

                    <!-- Folder picker -->
                    <TextBlock Margin="0,20,0,4" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Destination folder" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" IsReadOnly="True"
                                 Text="{Binding CloudBackupFolder}"
                                 VerticalContentAlignment="Center" />
                        <Button Grid.Column="1" Margin="8,0,0,0"
                                Command="{Binding BrowseCloudBackupFolderCommand}"
                                Content="Browse…"
                                Style="{StaticResource BaseButtonStyle}" />
                        <Button Grid.Column="2" Margin="8,0,0,0"
                                Command="{Binding ClearCloudBackupFolderCommand}"
                                Content="Clear"
                                Style="{StaticResource BaseButtonStyle}" />
                    </Grid>

                    <!-- Backups to keep -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Backups to keep (1–30)  " />
                        <TextBox Grid.Column="1"
                                 Text="{Binding MaxBackupsToKeep, UpdateSourceTrigger=LostFocus}" />
                    </Grid>

                    <!-- Warning: no folder -->
                    <Border Margin="0,16,0,0" Padding="12,10"
                            Background="#FFF3CD" BorderBrush="#FFC107"
                            BorderThickness="1" CornerRadius="6"
                            Visibility="{Binding IsBackupConfigured, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Foreground="#856404" TextWrapping="Wrap"
                                   Text="⚠  No destination folder set — automatic backup is disabled." />
                    </Border>

                    <!-- Status -->
                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding BackupStatusMessage}"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsBackupConfigured, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- Actions -->
                    <WrapPanel Margin="0,20,0,0">
                        <Button Margin="0,0,10,0"
                                Command="{Binding BackupNowCommand}"
                                Content="Backup Now"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Command="{Binding ToggleAutoBackupCommand}"
                                Content="{Binding ToggleAutoBackupLabel}"
                                Style="{StaticResource BaseButtonStyle}" />
                    </WrapPanel>

                </StackPanel>
            </Border>

            <!-- Updates -->
            <Border Margin="0,20,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Application Updates" />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="Current version  " />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="{Binding CurrentVersionText}" />
                    </Grid>

                    <TextBlock Margin="0,16,0,4" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="GitHub repo (owner/repo)" />
                    <TextBox Text="{Binding UpdateRepoSlug, UpdateSourceTrigger=LostFocus}"
                             ToolTip="e.g. MarianoAkiki/swm-releases" />

                    <!-- Status message -->
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding UpdateStatusMessage}"
                               TextWrapping="Wrap"
                               Visibility="{Binding UpdateStatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                    <!-- Download progress bar -->
                    <ProgressBar Margin="0,12,0,0"
                                 Style="{StaticResource UpdateProgressBarStyle}"
                                 Value="{Binding DownloadProgress}"
                                 Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <WrapPanel Margin="0,16,0,0">
                        <Button Margin="0,0,10,0"
                                Command="{Binding CheckForUpdateCommand}"
                                Content="Check for Update"
                                IsEnabled="{Binding IsNotDownloadingUpdate}"
                                Style="{StaticResource BaseButtonStyle}" />
                        <Button Command="{Binding DownloadUpdateCommand}"
                                Content="Download &amp; Install Update"
                                IsEnabled="{Binding IsUpdateAvailable}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Restore -->
            <Border Margin="0,20,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Restore" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Replace the current database with a previously backed-up file. The app must be restarted after restoring." />
                    <WrapPanel Margin="0,20,0,0">
                        <Button Command="{Binding RestoreDatabaseCommand}"
                                Content="Restore from Backup"
                                Style="{StaticResource BaseButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
