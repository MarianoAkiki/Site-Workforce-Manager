<UserControl x:Class="Site_Workforce_Manager.Views.TradesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />

        <Style x:Key="TableActionButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="64" />
        </Style>

        <Style x:Key="StatusToggleStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Width="96"
                                Padding="10,5"
                                Background="#F1F5F9"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock x:Name="ToggleText"
                                       HorizontalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="Inactive" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#ECFDF5" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#A7F3D0" />
                                <Setter Property="Foreground" Value="#047857" />
                                <Setter TargetName="ToggleText" Property="Text" Value="Active" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Visibility="{Binding IsTradeFormVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleTextStyle}"
                               Text="Categories" />
                    <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                               Text="Search, review, and maintain the approved category list used by workers." />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,24,0,0"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                           Text="Categories List" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Use quick search to find categories by name or description in the current status view." />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="12,8"
                                    Background="#EFF6FF"
                                    BorderBrush="{StaticResource PrimarySoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Text="{Binding StatusFilterLabel}" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,20,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <TextBox MinHeight="42"
                                         Padding="12,9,42,9"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Search by category name or description" />
                                <Button Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ClearSearchCommand}"
                                        Content="X"
                                        Style="{StaticResource FilterClearButtonStyle}"
                                        Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}" />
                            </Grid>

                            <Button Grid.Column="2"
                                    Command="{Binding ToggleStatusFilterCommand}"
                                    Content="{Binding StatusFilterButtonText}"
                                    Style="{StaticResource BaseButtonStyle}" />

                            <Button Grid.Column="4"
                                    MinWidth="48"
                                    Command="{Binding OpenAddTradeFormCommand}"
                                    Content="+"
                                    FontSize="18"
                                    ToolTip="Add category"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>

                        <DataGrid Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding TradesPage.Items}"
                                  SelectedItem="{Binding SelectedTrade, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Name}" Header="Category Name" Width="180" />
                                <DataGridTextColumn Binding="{Binding Description}" Header="Description" Width="*" />
                                <DataGridTemplateColumn Header="Status" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ToggleButton HorizontalAlignment="Left"
                                                          Command="{Binding DataContext.ToggleTradeStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"
                                                          IsChecked="{Binding IsActive, Mode=OneWay}"
                                                          Style="{StaticResource StatusToggleStyle}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding DeactivatedAt, StringFormat={}{0:MMM dd, yyyy}}" Header="Deactivated" Width="120"
                                                    Visibility="{Binding Data.DeactivatedColumnVisibility, Source={StaticResource Proxy}}" />
                                <DataGridTextColumn Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd}}" Header="Created" Width="110" />
                                <DataGridTextColumn Binding="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd}}" Header="Updated" Width="110" />
                                <DataGridTemplateColumn Header="Actions" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.OpenEditTradeFormCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Edit"
                                                    Style="{StaticResource TableActionButtonStyle}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Margin="0,14,0,0"
                                    HorizontalAlignment="Center" Orientation="Horizontal">
                            <Button Command="{Binding TradesPage.PreviousPageCommand}"
                                    Content="&lt; Prev" MinWidth="76"
                                    Style="{StaticResource BaseButtonStyle}" />
                            <TextBlock Margin="14,0" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       Text="{Binding TradesPage.PageInfoText}" />
                            <Button Command="{Binding TradesPage.NextPageCommand}"
                                    Content="Next &gt;" MinWidth="76"
                                    Style="{StaticResource BaseButtonStyle}" />
                            <TextBlock Margin="20,0,6,0" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       Text="Show:" />
                            <ComboBox MinWidth="68"
                                      ItemsSource="{x:Static helpers:PageSizeOptions.Values}"
                                      SelectedItem="{Binding TradesPage.PageSize, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                </Border>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsTradeFormVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleTextStyle}"
                               Text="{Binding FormTitle}" />
                    <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                               Text="{Binding FormDescription}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,24,0,0"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="Category Information" />

                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Category Name" />
                            <TextBox MinHeight="48"
                                     FontSize="15"
                                     Text="{Binding TradeName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Description" />
                            <TextBox MinHeight="180"
                                     AcceptsReturn="True"
                                     FontSize="15"
                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top" />
                        </StackPanel>

                        <StackPanel Margin="0,24,0,0" Orientation="Horizontal">
                            <Button Margin="0,0,12,0"
                                    Command="{Binding SaveTradeCommand}"
                                    Content="{Binding SaveButtonText}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Command="{Binding CancelTradeFormCommand}"
                                    Content="Cancel"
                                    Style="{StaticResource BaseButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
