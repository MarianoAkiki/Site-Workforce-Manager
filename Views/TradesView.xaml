<UserControl x:Class="Site_Workforce_Manager.Views.TradesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}"
                           Text="Trades" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="Manage worker trades and keep the worker forms consistent with the approved trade list." />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Trade Details" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Add a new trade or update the selected trade." />

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Trade Name" />
                            <TextBox Text="{Binding TradeName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Description" />
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
                        <Button Margin="0,0,12,0"
                                Command="{Binding AddTradeCommand}"
                                Content="Add Trade"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Margin="0,0,12,0"
                                Command="{Binding EditSelectedTradeCommand}"
                                Content="Edit Selected"
                                Style="{StaticResource BaseButtonStyle}" />
                        <Button Command="{Binding DeactivateSelectedTradeCommand}"
                                Content="Deactivate"
                                Style="{StaticResource DangerButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Trades List" />
                    <TextBlock Margin="0,6,0,16"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Trades already used by workers should be deactivated instead of deleted." />

                    <DataGrid AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding Trades}"
                              SelectedItem="{Binding SelectedTrade, Mode=TwoWay}"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Header="Trade Name" Width="180" />
                            <DataGridTextColumn Binding="{Binding Description}" Header="Description" Width="*" />
                            <DataGridCheckBoxColumn Binding="{Binding IsActive}" Header="Active" Width="90" />
                            <DataGridTextColumn Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd}}" Header="Created" Width="110" />
                            <DataGridTextColumn Binding="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd}}" Header="Updated" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
