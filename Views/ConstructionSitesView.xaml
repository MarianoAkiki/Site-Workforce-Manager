<UserControl x:Class="Site_Workforce_Manager.Views.ConstructionSitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}"
                           Text="Construction Sites" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="Maintain active sites, update location details, and manage site status." />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Site Details" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Add a new construction site or update the selected one." />

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Site Name" />
                            <TextBox Text="{Binding SiteName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Location" />
                            <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
                        <Button Margin="0,0,12,0"
                                Command="{Binding AddSiteCommand}"
                                Content="Add Site"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Margin="0,0,12,0"
                                Command="{Binding EditSelectedSiteCommand}"
                                Content="Edit Selected"
                                Style="{StaticResource BaseButtonStyle}" />
                        <Button Command="{Binding DeactivateSelectedSiteCommand}"
                                Content="Deactivate"
                                Style="{StaticResource DangerButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Construction Sites List" />
                    <TextBlock Margin="0,6,0,16"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Select a site to edit details or update its status." />

                    <DataGrid AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding ConstructionSites}"
                              SelectedItem="{Binding SelectedConstructionSite, Mode=TwoWay}"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Id}" Header="Id" Width="70" />
                            <DataGridTextColumn Binding="{Binding Name}" Header="Site Name" Width="*" />
                            <DataGridTextColumn Binding="{Binding Location}" Header="Location" Width="*" />
                            <DataGridTextColumn Binding="{Binding Status}" Header="Status" Width="130" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
