<UserControl x:Class="Site_Workforce_Manager.Views.PayrollView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <Style x:Key="InlineClearButtonStyle" TargetType="Button" BasedOn="{StaticResource FilterClearButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="ToolTip" Value="Clear filter" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}"
                           Text="Payroll" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="Review worker balances and enter weekly payments by trade." />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,16,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Payroll Week" />
                        <StackPanel Orientation="Horizontal">
                            <Button MinWidth="44"
                                    Command="{Binding PreviousWeekCommand}"
                                    Content="&lt;"
                                    Style="{StaticResource BaseButtonStyle}" />
                            <Border MinWidth="360"
                                    Margin="12,0"
                                    Padding="14,8"
                                    Background="#F8FAFC"
                                    BorderBrush="#D9E2EC"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding WeekRangeText}" />
                            </Border>
                            <Button MinWidth="44"
                                    Command="{Binding NextWeekCommand}"
                                    Content="&gt;"
                                    IsEnabled="{Binding CanGoNextWeek}"
                                    Style="{StaticResource BaseButtonStyle}" />
                        </StackPanel>
                    </StackPanel>


                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding StatusMessage}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="ID" />
                            <Grid>
                                <TextBox MinHeight="30"
                                         Padding="6,4,20,4"
                                         FontSize="12"
                                         Text="{Binding WorkerIdFilterText, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="0,0,3,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ClearWorkerIdFilterCommand}"
                                        Content="x"
                                        Style="{StaticResource InlineClearButtonStyle}"
                                        Visibility="{Binding WorkerIdFilterText, Converter={StaticResource StringToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Worker Name" />
                            <Grid>
                                <TextBox MinHeight="30"
                                         Padding="8,4,28,4"
                                         FontSize="12"
                                         Text="{Binding WorkerNameFilterText, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="0,0,5,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ClearWorkerNameFilterCommand}"
                                        Content="x"
                                        Style="{StaticResource InlineClearButtonStyle}"
                                        Visibility="{Binding WorkerNameFilterText, Converter={StaticResource StringToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Trade" />
                            <Grid>
                                <TextBox MinHeight="30"
                                         Padding="8,4,28,4"
                                         FontSize="12"
                                         Text="{Binding TradeFilterText, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="0,0,5,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ClearTradeFilterCommand}"
                                        Content="x"
                                        Style="{StaticResource InlineClearButtonStyle}"
                                        Visibility="{Binding TradeFilterText, Converter={StaticResource StringToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="10"
                                Background="#F1F5F9"
                                BorderBrush="#D9E2EC"
                                BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="ID" />
                        </Border>
                        <Border Grid.Column="1"
                                Padding="10"
                                Background="#F1F5F9"
                                BorderBrush="#D9E2EC"
                                BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="Worker" />
                        </Border>
                        <Border Grid.Column="2"
                                Padding="10"
                                Background="#F1F5F9"
                                BorderBrush="#D9E2EC"
                                BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="{Binding BalanceHeaderText}" />
                        </Border>
                        <Border Grid.Column="3"
                                Padding="10"
                                Background="#F1F5F9"
                                BorderBrush="#D9E2EC"
                                BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="{Binding PaymentHeaderText}" />
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding FilteredTradeGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Padding="12,9"
                                            Background="#DBEAFE"
                                            BorderBrush="#93C5FD"
                                            BorderThickness="0,0,0,1">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="#1E3A8A"
                                                   Text="{Binding TradeName}" />
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="170" />
                                                        <ColumnDefinition Width="180" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            MinHeight="44"
                                                            Padding="10"
                                                            BorderBrush="#E2E8F0"
                                                            BorderThickness="0,0,1,1">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   Text="{Binding WorkerId}" />
                                                    </Border>
                                                    <Border Grid.Column="1"
                                                            MinHeight="44"
                                                            Padding="10"
                                                            BorderBrush="#E2E8F0"
                                                            BorderThickness="0,0,1,1">
                                                        <Grid>
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Text="{Binding WorkerName}" />
                                                            <Button HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Width="26"
                                                                    Height="26"
                                                                    Padding="0"
                                                                    FontSize="12"
                                                                    Content="⊙"
                                                                    ToolTip="View current balance"
                                                                    Command="{Binding ShowLiveBalanceCommand}"
                                                                    Style="{StaticResource BaseButtonStyle}" />
                                                            <Popup IsOpen="{Binding IsLiveBalancePopupOpen, Mode=TwoWay}"
                                                                   Placement="Mouse"
                                                                   StaysOpen="False"
                                                                   AllowsTransparency="True">
                                                                <Border Background="White"
                                                                        BorderBrush="#BFDBFE"
                                                                        BorderThickness="1"
                                                                        CornerRadius="10"
                                                                        Padding="18,14"
                                                                        MinWidth="200"
                                                                        Margin="6">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect Color="#1E3A8A"
                                                                                          Opacity="0.12"
                                                                                          BlurRadius="16"
                                                                                          ShadowDepth="4"
                                                                                          Direction="270" />
                                                                    </Border.Effect>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding WorkerName}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="13"
                                                                                   Foreground="#1E3A8A"
                                                                                   Margin="0,0,0,8" />
                                                                        <Separator Background="#E2E8F0" Margin="0,0,0,8" />
                                                                        <TextBlock Text="Current Balance"
                                                                                   FontSize="11"
                                                                                   Foreground="#64748B"
                                                                                   Margin="0,0,0,3" />
                                                                        <TextBlock Text="{Binding LiveBalanceDisplay}"
                                                                                   FontSize="22"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#0F172A" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Popup>
                                                        </Grid>
                                                    </Border>
                                                    <Border Grid.Column="2"
                                                            MinHeight="44"
                                                            Padding="10"
                                                            BorderBrush="#E2E8F0"
                                                            BorderThickness="0,0,1,1">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding BalanceDisplay}" />
                                                    </Border>
                                                    <Border Grid.Column="3"
                                                            MinHeight="44"
                                                            Padding="8"
                                                            BorderBrush="#E2E8F0"
                                                            BorderThickness="0,0,1,1">
                                                        <TextBox MinHeight="30"
                                                                 IsReadOnly="{Binding IsPaymentReadOnly}"
                                                                 Text="{Binding PaymentAmountText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Background="#E0F2FE">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="180" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="1"
                                                Padding="10"
                                                BorderBrush="#BAE6FD"
                                                BorderThickness="0,0,1,1">
                                            <TextBlock FontWeight="SemiBold" Text="Trade Total" />
                                        </Border>
                                        <Border Grid.Column="2"
                                                Padding="10"
                                                BorderBrush="#BAE6FD"
                                                BorderThickness="0,0,1,1">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding TotalBalanceDisplay}" />
                                        </Border>
                                        <Border Grid.Column="3"
                                                Padding="10"
                                                BorderBrush="#BAE6FD"
                                                BorderThickness="0,0,1,1">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding TotalPaymentDisplay}" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Margin="0,12,0,0"
                          Background="#DBEAFE">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="1"
                                Padding="12">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Grand Total" />
                        </Border>
                        <Border Grid.Column="2"
                                Padding="12">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding GrandTotalBalanceDisplay}" />
                        </Border>
                        <Border Grid.Column="3"
                                Padding="12">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding GrandTotalPaymentDisplay}" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
