<UserControl x:Class="Site_Workforce_Manager.Views.WeeklyWorkEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="WeeklyCellTemplate">
            <Border MinHeight="86"
                    Padding="6"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,1,1">
                <StackPanel>
                    <TextBox MinHeight="30"
                             Padding="7,4"
                             FontSize="12"
                             IsReadOnly="{Binding IsReadOnly}"
                             ToolTip="Duration in hours"
                             Text="{Binding DurationHoursText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox MinHeight="30"
                              Margin="0,7,0,0"
                              Padding="4,2"
                              FontSize="11"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding ConstructionSiteOptions}"
                              SelectedItem="{Binding SelectedConstructionSiteOption, Mode=TwoWay}"
                              ToolTip="Assigned construction site" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}"
                           Text="Weekly Work Entry" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="Enter worker hours by trade for the latest completed Thursday-to-Wednesday week." />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Trade" />
                        <ComboBox MinHeight="42"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{Binding TradeOptions}"
                                  SelectedItem="{Binding SelectedTradeOption, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Week" />
                        <StackPanel Orientation="Horizontal">
                            <Button MinWidth="44"
                                    Command="{Binding PreviousWeekCommand}"
                                    Content="&lt;"
                                    Style="{StaticResource BaseButtonStyle}" />
                            <Border MinWidth="360"
                                    Margin="12,0"
                                    Padding="16,10"
                                    Background="#F8FAFC"
                                    BorderBrush="#D9E2EC"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding WeekRangeText}" />
                            </Border>
                            <Button MinWidth="44"
                                    Command="{Binding NextWeekCommand}"
                                    Content="&gt;"
                                    IsEnabled="{Binding CanGoNextWeek}"
                                    Style="{StaticResource BaseButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2"
                            MinWidth="140"
                            VerticalAlignment="Bottom"
                            Command="{Binding SaveWeekCommand}"
                            Content="Save Week"
                            Style="{StaticResource PrimaryButtonStyle}" />

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="3"
                               Margin="0,18,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding StatusMessage}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" MinWidth="88" />
                        <ColumnDefinition Width="*" MinWidth="88" />
                        <ColumnDefinition Width="*" MinWidth="88" />
                        <ColumnDefinition Width="*" MinWidth="88" />
                        <ColumnDefinition Width="*" MinWidth="88" />
                        <ColumnDefinition Width="*" MinWidth="88" />
                        <ColumnDefinition Width="*" MinWidth="88" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            MinHeight="46"
                            Padding="6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="ID" />
                    </Border>
                    <Border Grid.Column="1"
                            MinHeight="46"
                            Padding="8,6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="Worker" />
                    </Border>

                    <Border Grid.Column="2"
                            MinHeight="46"
                            Padding="7,6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding WeekDays[0].Header}" />
                    </Border>
                    <Border Grid.Column="3"
                            MinHeight="46"
                            Padding="7,6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding WeekDays[1].Header}" />
                    </Border>
                    <Border Grid.Column="4"
                            MinHeight="46"
                            Padding="7,6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding WeekDays[2].Header}" />
                    </Border>
                    <Border Grid.Column="5"
                            MinHeight="46"
                            Padding="7,6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding WeekDays[3].Header}" />
                    </Border>
                    <Border Grid.Column="6"
                            MinHeight="46"
                            Padding="7,6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding WeekDays[4].Header}" />
                    </Border>
                    <Border Grid.Column="7"
                            MinHeight="46"
                            Padding="7,6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding WeekDays[5].Header}" />
                    </Border>
                    <Border Grid.Column="8"
                            MinHeight="46"
                            Padding="7,6"
                            Background="#F1F5F9"
                            BorderBrush="#D9E2EC"
                            BorderThickness="0,0,1,1">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="{Binding WeekDays[6].Header}" />
                    </Border>

                    <ItemsControl Grid.Row="1"
                                  Grid.ColumnSpan="9"
                                  ItemsSource="{Binding WorkerRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" MinWidth="88" />
                                        <ColumnDefinition Width="*" MinWidth="88" />
                                        <ColumnDefinition Width="*" MinWidth="88" />
                                        <ColumnDefinition Width="*" MinWidth="88" />
                                        <ColumnDefinition Width="*" MinWidth="88" />
                                        <ColumnDefinition Width="*" MinWidth="88" />
                                        <ColumnDefinition Width="*" MinWidth="88" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            MinHeight="86"
                                            Padding="6"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0,0,1,1">
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding WorkerId}" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            MinHeight="86"
                                            Padding="8,6"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0,0,1,1">
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding WorkerName}" />
                                    </Border>

                                    <ContentControl Grid.Column="2"
                                                    Content="{Binding Cells[0]}"
                                                    ContentTemplate="{StaticResource WeeklyCellTemplate}" />
                                    <ContentControl Grid.Column="3"
                                                    Content="{Binding Cells[1]}"
                                                    ContentTemplate="{StaticResource WeeklyCellTemplate}" />
                                    <ContentControl Grid.Column="4"
                                                    Content="{Binding Cells[2]}"
                                                    ContentTemplate="{StaticResource WeeklyCellTemplate}" />
                                    <ContentControl Grid.Column="5"
                                                    Content="{Binding Cells[3]}"
                                                    ContentTemplate="{StaticResource WeeklyCellTemplate}" />
                                    <ContentControl Grid.Column="6"
                                                    Content="{Binding Cells[4]}"
                                                    ContentTemplate="{StaticResource WeeklyCellTemplate}" />
                                    <ContentControl Grid.Column="7"
                                                    Content="{Binding Cells[5]}"
                                                    ContentTemplate="{StaticResource WeeklyCellTemplate}" />
                                    <ContentControl Grid.Column="8"
                                                    Content="{Binding Cells[6]}"
                                                    ContentTemplate="{StaticResource WeeklyCellTemplate}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
