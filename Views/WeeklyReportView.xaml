<UserControl x:Class="Site_Workforce_Manager.Views.WeeklyReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="ReportCellStyle" TargetType="DataGridCell">
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="3,3" />
        </Style>
        <Style x:Key="ReportHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="3,5" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Weekly Report" />
            <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                       Text="Worker hours, earnings and balance summary for the selected week." />
        </StackPanel>

        <!-- Week navigation + Category filter -->
        <Border Grid.Row="1" Margin="0,20,0,0" Padding="20,16"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Category filter (mandatory — left side) -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                    <TextBlock Text="CATEGORY"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding Trades}"
                              SelectedItem="{Binding SelectedTrade, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              MinWidth="180"
                              IsEditable="False">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="8,4" />
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <!-- Week picker (center) -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding PreviousWeekCommand}"
                                Content="&lt;"
                                Style="{StaticResource BaseButtonStyle}"
                                MinWidth="44" />
                        <TextBlock Text="{Binding WeekRangeText}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="16,0" MinWidth="320"
                                   TextAlignment="Center" />
                        <Button Command="{Binding NextWeekCommand}"
                                Content="&gt;"
                                Style="{StaticResource BaseButtonStyle}"
                                IsEnabled="{Binding CanGoNextWeek}"
                                MinWidth="44" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center" Margin="0,8,0,0" Orientation="Horizontal">
                        <DatePicker DisplayDateEnd="{Binding MaxPickerDate, Mode=OneWay}"
                                    SelectedDate="{Binding PickerDate, Mode=TwoWay}"
                                    ToolTip="Pick any date to jump to that week" />
                        <Button Margin="8,0,0,0" Command="{Binding GoToTodayCommand}"
                                Content="Today" Style="{StaticResource BaseButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <!-- Print button (right side) -->
                <Button Grid.Column="2" VerticalAlignment="Center" Margin="24,0,0,0"
                        Command="{Binding PrintCommand}"
                        Content="⊞ Print"
                        Style="{StaticResource BaseButtonStyle}" />
            </Grid>
        </Border>

        <!-- Row count info -->
        <TextBlock Grid.Row="2" Margin="0,12,0,8"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="12"
                   Text="{Binding Rows.Count, StringFormat={}{0} worker(s)}" />

        <!-- Table -->
        <Grid Grid.Row="3">
            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      FontSize="11"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      BorderThickness="1"
                      BorderBrush="{StaticResource BorderBrush}"
                      ColumnHeaderStyle="{StaticResource ReportHeaderStyle}"
                      CellStyle="{StaticResource ReportCellStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTotalsRow}" Value="True">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding WorkerId}"
                                        Width="32" />

                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding WorkerName}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Left" />
                                <Setter Property="Padding" Value="4,0,0,0" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Day columns — two-line header: day name + date -->
                    <DataGridTextColumn Binding="{Binding Day0Display}" Width="50">
                        <DataGridTextColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DataContext.DayName0, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding DataContext.DayDate0, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Day1Display}" Width="50">
                        <DataGridTextColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DataContext.DayName1, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding DataContext.DayDate1, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Day2Display}" Width="50">
                        <DataGridTextColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DataContext.DayName2, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding DataContext.DayDate2, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Day3Display}" Width="50">
                        <DataGridTextColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DataContext.DayName3, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding DataContext.DayDate3, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Day4Display}" Width="50">
                        <DataGridTextColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DataContext.DayName4, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding DataContext.DayDate4, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Day5Display}" Width="50">
                        <DataGridTextColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DataContext.DayName5, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding DataContext.DayDate5, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Day6Display}" Width="50">
                        <DataGridTextColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DataContext.DayName6, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding DataContext.DayDate6, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           TextAlignment="Center" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Hrs"
                                        Binding="{Binding TotalHoursDisplay}"
                                        Width="46" />

                    <DataGridTextColumn Header="Days"
                                        Binding="{Binding NumberOfDays}"
                                        Width="36" />

                    <DataGridTextColumn Header="Rate"
                                        Binding="{Binding DailyRateDisplay}"
                                        Width="62" />

                    <DataGridTextColumn Header="Pre-Bal."
                                        Binding="{Binding BalanceBeforeWeekDisplay}"
                                        Width="72" />

                    <DataGridTextColumn Header="Earned"
                                        Binding="{Binding WeekEarningsDisplay}"
                                        Width="72" />

                    <DataGridTextColumn Header="Tot. Earned"
                                        Binding="{Binding TotalEarnedDisplay}"
                                        Width="78" />

                    <DataGridTextColumn Header="Tot. Paid"
                                        Binding="{Binding TotalPaidDisplay}"
                                        Width="72" />

                    <DataGridTextColumn Header="Still Owed"
                                        Binding="{Binding TotalBalanceDisplay}"
                                        Width="78" />

                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading overlay -->
            <Border Background="#CCFFFFFF"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                           Text="Loading..." />
            </Border>
        </Grid>
    </Grid>
</UserControl>
