<Window x:Class="Site_Workforce_Manager.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="420"
        Height="300"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Fill" Value="#2563EB"/>
            <Setter Property="Opacity" Value="0.3"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20"
            Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.18" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Main content -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40,40,40,20">

                <!-- Icon -->
                <Image Source="pack://application:,,,/app-logo.png"
                       Width="80"
                       Height="80"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,0,20"/>

                <!-- App name -->
                <TextBlock Text="Site Workforce Manager"
                           Foreground="#0F172A"
                           FontSize="22"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <!-- Subtitle -->
                <TextBlock Text="Loading your workspace…"
                           Foreground="#64748B"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Animated dots -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Ellipse x:Name="Dot1" Style="{StaticResource DotStyle}">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="Dot1"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.5"
                                                         AutoReverse="True"
                                                         BeginTime="0:0:0"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse x:Name="Dot2" Style="{StaticResource DotStyle}">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="Dot2"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.5"
                                                         AutoReverse="True"
                                                         BeginTime="0:0:0.17"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse x:Name="Dot3" Style="{StaticResource DotStyle}">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="Dot3"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.5"
                                                         AutoReverse="True"
                                                         BeginTime="0:0:0.34"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </StackPanel>
            </StackPanel>

            <!-- Version footer -->
            <TextBlock Grid.Row="1"
                       Text="v1.0"
                       Foreground="#94A3B8"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>
        </Grid>
    </Border>
</Window>
