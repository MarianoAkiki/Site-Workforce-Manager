<UserControl x:Class="Site_Workforce_Manager.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Dashboard" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="{Binding MonthLabel, StringFormat=Quick overview for {0}.}" />
            </StackPanel>

            <Border Grid.Row="1" Margin="0,24,0,0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Summary" />
                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}"
                               Text="Workforce activity and labor totals at a glance." />

                    <UniformGrid Margin="0,20,0,0" Columns="3" Rows="2">

                        <!-- Active Workers -->
                        <Border Margin="0,0,14,14" Style="{StaticResource SummaryCardBorderStyle}">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="#EFF6FF" HorizontalAlignment="Left" Margin="0,0,0,14">
                                    <TextBlock Text="👷" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               LineHeight="22" />
                                </Border>
                                <TextBlock FontSize="28" FontWeight="Bold" LineHeight="32"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ActiveWorkers}" />
                                <TextBlock Margin="0,4,0,0" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Active Workers" />
                            </StackPanel>
                        </Border>

                        <!-- Active Construction Sites -->
                        <Border Margin="0,0,14,14" Style="{StaticResource SummaryCardBorderStyle}">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="#ECFDF5" HorizontalAlignment="Left" Margin="0,0,0,14">
                                    <TextBlock Text="🏗️" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               LineHeight="22" />
                                </Border>
                                <TextBlock FontSize="28" FontWeight="Bold" LineHeight="32"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ActiveConstructionSites}" />
                                <TextBlock Margin="0,4,0,0" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Active Sites" />
                            </StackPanel>
                        </Border>

                        <!-- Total Hours This Month -->
                        <Border Margin="0,0,0,14" Style="{StaticResource SummaryCardBorderStyle}">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="#F5F3FF" HorizontalAlignment="Left" Margin="0,0,0,14">
                                    <TextBlock Text="⏱️" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               LineHeight="22" />
                                </Border>
                                <TextBlock FontSize="28" FontWeight="Bold" LineHeight="32"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding TotalHoursThisMonth, StringFormat={}{0:F1}}" />
                                <TextBlock Margin="0,4,0,0" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Hours This Month" />
                            </StackPanel>
                        </Border>

                        <!-- Total Labor Cost This Month -->
                        <Border Margin="0,0,14,0" Style="{StaticResource SummaryCardBorderStyle}">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="#FFFBEB" HorizontalAlignment="Left" Margin="0,0,0,14">
                                    <TextBlock Text="💰" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               LineHeight="22" />
                                </Border>
                                <TextBlock FontSize="28" FontWeight="Bold" LineHeight="32"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding TotalLaborCostThisMonth, StringFormat={}{0:C}}" />
                                <TextBlock Margin="0,4,0,0" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Labor Cost This Month" />
                            </StackPanel>
                        </Border>

                        <!-- Work Logs Count -->
                        <Border Margin="0,0,14,0" Style="{StaticResource SummaryCardBorderStyle}">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="#FFF7ED" HorizontalAlignment="Left" Margin="0,0,0,14">
                                    <TextBlock Text="📋" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               LineHeight="22" />
                                </Border>
                                <TextBlock FontSize="28" FontWeight="Bold" LineHeight="32"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding WorkLogsCount}" />
                                <TextBlock Margin="0,4,0,0" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Work Log Entries" />
                            </StackPanel>
                        </Border>

                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
