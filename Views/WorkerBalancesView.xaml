<UserControl x:Class="Site_Workforce_Manager.Views.WorkerBalancesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Site_Workforce_Manager.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <Style x:Key="InlineClearButtonStyle" TargetType="Button" BasedOn="{StaticResource FilterClearButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="ToolTip" Value="Clear filter" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Worker Balances" />
                <TextBlock Style="{StaticResource PageSubtitleTextStyle}"
                           Text="Current balance for each worker based on all work logs and payments to date." />
            </StackPanel>

            <Border Grid.Row="1" Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="ID" />
                        <Grid>
                            <TextBox MinHeight="30" Padding="6,4,20,4" FontSize="12"
                                     Text="{Binding WorkerIdFilterText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,3,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Command="{Binding ClearWorkerIdFilterCommand}" Content="x"
                                    Style="{StaticResource InlineClearButtonStyle}"
                                    Visibility="{Binding WorkerIdFilterText, Converter={StaticResource StringToVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Worker Name" />
                        <Grid>
                            <TextBox MinHeight="30" Padding="8,4,28,4" FontSize="12"
                                     Text="{Binding WorkerNameFilterText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Command="{Binding ClearWorkerNameFilterCommand}" Content="x"
                                    Style="{StaticResource InlineClearButtonStyle}"
                                    Visibility="{Binding WorkerNameFilterText, Converter={StaticResource StringToVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="Category" />
                        <Grid>
                            <TextBox MinHeight="30" Padding="8,4,28,4" FontSize="12"
                                     Text="{Binding TradeFilterText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Command="{Binding ClearTradeFilterCommand}" Content="x"
                                    Style="{StaticResource InlineClearButtonStyle}"
                                    Visibility="{Binding TradeFilterText, Converter={StaticResource StringToVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,2">
                        <Button Margin="0,0,16,0"
                                Command="{Binding ToggleShowActiveWorkersCommand}"
                                Content="{Binding StatusToggleButtonText}"
                                Style="{StaticResource BaseButtonStyle}" />
                        <CheckBox VerticalAlignment="Center"
                                  IsChecked="{Binding ShowOnlyWithBalance}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Content="Outstanding balance only" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="0,20,0,0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="10,8" Background="#F1F5F9" BorderBrush="#D9E2EC" BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="ID" />
                        </Border>
                        <Border Grid.Column="1" Padding="10,8" Background="#F1F5F9" BorderBrush="#D9E2EC" BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="Worker" />
                        </Border>
                        <Border Grid.Column="2" Padding="10,8" Background="#F1F5F9" BorderBrush="#D9E2EC" BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="Category" />
                        </Border>
                        <Border Grid.Column="3" Padding="10,8" Background="#F1F5F9" BorderBrush="#D9E2EC" BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="Total Earned" />
                        </Border>
                        <Border Grid.Column="4" Padding="10,8" Background="#F1F5F9" BorderBrush="#D9E2EC" BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="Total Paid" />
                        </Border>
                        <Border Grid.Column="5" Padding="10,8" Background="#F1F5F9" BorderBrush="#D9E2EC" BorderThickness="0,0,1,1">
                            <TextBlock FontWeight="SemiBold" Text="Balance" />
                        </Border>
                    </Grid>

                    <!-- Rows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RowsPage.Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" MinHeight="40" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding WorkerId}" />
                                    </Border>
                                    <Border Grid.Column="1" MinHeight="40" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding WorkerName}" />
                                    </Border>
                                    <Border Grid.Column="2" MinHeight="40" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Text="{Binding TradeName}" />
                                    </Border>
                                    <Border Grid.Column="3" MinHeight="40" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding TotalEarnedDisplay}" />
                                    </Border>
                                    <Border Grid.Column="4" MinHeight="40" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                        <TextBlock VerticalAlignment="Center" Text="{Binding TotalPaidDisplay}" />
                                    </Border>
                                    <Border Grid.Column="5" MinHeight="40" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding BalanceDisplay}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#047857" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Balance}" Value="0">
                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>

                    <!-- Totals -->
                    <Grid Grid.Row="2" Margin="0,0,0,0" Background="#DBEAFE">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="2" Padding="10,12">
                            <TextBlock FontWeight="SemiBold" FontSize="14" Text="Grand Total" />
                        </Border>
                        <Border Grid.Column="3" Padding="10,12">
                            <TextBlock FontWeight="SemiBold" FontSize="14" Text="{Binding GrandTotalEarnedDisplay}" />
                        </Border>
                        <Border Grid.Column="4" Padding="10,12">
                            <TextBlock FontWeight="SemiBold" FontSize="14" Text="{Binding GrandTotalPaidDisplay}" />
                        </Border>
                        <Border Grid.Column="5" Padding="10,12">
                            <TextBlock FontWeight="SemiBold" FontSize="14" Text="{Binding GrandTotalBalanceDisplay}" Foreground="#1E3A8A" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,14,0,0"
                                HorizontalAlignment="Center" Orientation="Horizontal">
                        <Button Command="{Binding RowsPage.PreviousPageCommand}"
                                Content="&lt; Prev" MinWidth="76"
                                Style="{StaticResource BaseButtonStyle}" />
                        <TextBlock Margin="14,0" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   Text="{Binding RowsPage.PageInfoText}" />
                        <Button Command="{Binding RowsPage.NextPageCommand}"
                                Content="Next &gt;" MinWidth="76"
                                Style="{StaticResource BaseButtonStyle}" />
                        <TextBlock Margin="20,0,6,0" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   Text="Show:" />
                        <ComboBox MinWidth="68"
                                  ItemsSource="{x:Static helpers:PageSizeOptions.Values}"
                                  SelectedItem="{Binding RowsPage.PageSize, Mode=TwoWay}" />
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
</UserControl>
